<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>New Reply Notification</title>
    <style>
      /* Base Style Overrides */
      body {
        margin: 0;
        padding: 0;
        min-width: 100%;
        font-family: Arial, sans-serif;
        font-size: 16px;
        line-height: 1.5;
        background-color: #fafafa;
        color: #222222;
      }
      a {
        color: #0070f3;
        text-decoration: none;
      }
      h1 {
        font-size: 24px;
        font-weight: 700;
        line-height: 1.25;
        margin-top: 0;
        margin-bottom: 15px;
        text-align: center;
      }
      p {
        margin-top: 0;
        margin-bottom: 24px;
      }
      table td {
        vertical-align: top;
      }

      /* Layout Structure */
      .email-wrapper {
        max-width: 600px;
        margin: 0 auto;
      }
      .email-header {
        background-color: #0070f3;
        padding: 24px;
        color: #ffffff;
      }
      .email-body {
        padding: 24px;
        background-color: #ffffff;
      }
      .email-footer {
        background-color: #f6f6f6;
        padding: 24px;
      }

      /* Highlight Block Component */
      .highlight-box {
        background-color: #f4f9ff;
        border-left: 4px solid #0070f3;
        padding: 16px;
        margin-bottom: 24px;
        font-style: italic;
        color: #333333;
      }
    </style>
  </head>
  <body>
    <div class="email-wrapper">
      <!-- Consistent Header Segment -->
      <div class="email-header">
        <h1>LMS Discussion Update</h1>
      </div>

      <!-- Main Body Container -->
      <div class="email-body">
        <p>Hello <strong><%= name %></strong>,</p>
        
        <p>
          An instructor or a peer has just added a new reply to your discussion question regarding the video module:
        </p>

        <!-- Context Box to highlight the Title variable clearly -->
        <div class="highlight-box">
          "<%= title %>"
        </div>

        <p>
          Please log back into our learning platform portal to review the follow-up explanation and continue the thread discussion.
        </p>
        
        <p>
          Thank you for being an active participant in our engineering community!
        </p>
      </div>

      <!-- Consistent System Footer Segment -->
      <div class="email-footer">
        <p>
          If you have any questions or require account assistance, feel free to contact us at 
          <a href="mailto:support@lms.com">support@lms.com</a>
        </p>
      </div>
    </div>
  </body>
</html>